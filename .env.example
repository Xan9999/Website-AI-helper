# Copy to `.env` (or run `website-ai-helper init`). All values are optional.

# --- Chat + embedding endpoints (any OpenAI-compatible server) ---
LLM_BASE_URL=http://127.0.0.1:8080/v1
EMBED_BASE_URL=http://127.0.0.1:8081/v1
EMBED_DIM=768
# nomic-embed prefixes (set both to "" for a bge model)
EMBED_DOC_PREFIX="search_document: "
EMBED_QUERY_PREFIX="search_query: "

# --- Vector store ---
# Empty = embedded local folder (./data/qdrant). Set to a URL for a Qdrant server.
QDRANT_URL=
# One collection per website you serve:
QDRANT_COLLECTION=default

# --- Identity + retrieval tuning ---
SITE_NAME=this website
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=160
MAX_TOOL_ITERS=1
TEMPERATURE=0.2

# --- Crawler ---
CRAWL_MAX_PAGES=50
CRAWL_SAME_DOMAIN=1

# --- Where this install writes data (vector store, demo DB) ---
DATA_DIR=data
