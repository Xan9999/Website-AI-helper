# Copy to `.env` (or run `website-ai-helper init`).
# Use plain KEY=value lines (this is a dotenv file, NOT a PowerShell script —
# do not prefix lines with `$env:`). Two consumers read this file:
#   - the Python app  -> the LLM_BASE_URL / QDRANT_* / retrieval keys below
#   - scripts/start-*.ps1 -> the LLAMA_SERVER / CHAT_MODEL / EMBED_MODEL_PATH keys

# --- Local llama.cpp launcher settings (used only by scripts/start-*.ps1) ---
# Path to the llama-server binary and the .gguf model files it should load.
# Paths may contain spaces; no quotes needed. Leave unset if you start the
# servers some other way (or have llama-server on PATH).
LLAMA_SERVER=C:\path\to\llama-server.exe
CHAT_MODEL=..\models\Qwen3-14B-Instruct-Q4_K_M.gguf
EMBED_MODEL_PATH=..\models\bge-m3-Q8_0.gguf
# LLM_SLOTS (-np) = how many chats generate in parallel; LLM_CTX (-c) = TOTAL
# context tokens, split across slots (per-chat context = LLM_CTX / LLM_SLOTS).
# Keep LLM_CTX ~= LLM_SLOTS x 4096 for this app. Both cost VRAM on top of the
# model weights — e.g. an 11 GB card fits 2/8192 with a 14B model; a 32 GB
# card fits 10/40960 with a 32B model. Used by scripts/start-llm.{ps1,sh} AND
# docker-compose.yml.
LLM_SLOTS=2
LLM_CTX=8192
# CPU_MOE=1 keeps Mixture-of-Experts weights on CPU/RAM instead of VRAM,
# letting a big MoE model exceed your GPU's VRAM. Only relevant if you swap in
# an MoE model; harmless no-op for dense models like Qwen2.5. NOTE: measured
# on a GTX 1080 Ti, CPU-offloaded 20B+ MoE models ran 8-20x SLOWER than a
# dense 7B fully on GPU — prefer a dense model that fits your VRAM.
CPU_MOE=0
# Qdrant server binary + storage (used only by scripts/start-qdrant.ps1).
# Get it from https://github.com/qdrant/qdrant/releases (no Docker needed).
QDRANT_BIN=..\..\qdrant\qdrant.exe
QDRANT_STORAGE=..\..\qdrant\storage

# --- Chat + embedding endpoints (any OpenAI-compatible server) ---
LLM_BASE_URL=http://127.0.0.1:8080/v1
EMBED_BASE_URL=http://127.0.0.1:8081/v1
# EMBED_DIM must match your embedding model's output size:
#   bge-m3 (recommended, multilingual, 100+ languages) = 1024, no prefixes needed
#   nomic-embed-text (English-centric)                 = 768, needs the prefixes below
EMBED_DIM=1024
# Only needed for nomic-embed-text; leave blank for bge-m3 or bge-base.
EMBED_DOC_PREFIX=
EMBED_QUERY_PREFIX=

# --- Vector store ---
# Empty = embedded local folder (./data/qdrant), which allows only ONE process
# (ingest OR serve, not both) to open it at a time. Recommended: run a real
# Qdrant server (scripts/start-qdrant.ps1) and point at it here — lets ingest
# and serve run simultaneously.
QDRANT_URL=http://127.0.0.1:6333
# One collection per website you serve:
QDRANT_COLLECTION=default

# --- Identity + retrieval tuning ---
SITE_NAME=this website
# Per-collection site names when serving multiple sites (client_id = collection):
#   SITE_NAMES=acme=Acme Shop,adr=Adrlandia
# Collections without an entry fall back to SITE_NAME.
SITE_NAMES=
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=160
MAX_TOOL_ITERS=1
TEMPERATURE=0.2
# Anti-repetition / runaway-generation guards. Small local models occasionally
# degenerate into repeating themselves (sometimes drifting into another
# language mid-repeat, e.g. under a vague query with weak retrieval matches).
# These make that both less likely and less damaging when it happens.
FREQUENCY_PENALTY=0.4
PRESENCE_PENALTY=0.4
MAX_TOKENS=500
# Max characters of the visitor's current page injected into the prompt.
# Bigger = better "this page" answers but slower time-to-first-token.
PAGE_MAX_CHARS=1500

# --- Docker Compose deployment only (see README "Deploying on a GPU server") ---
# Filenames inside ./models (or MODELS_DIR) used by docker-compose.yml
# (LLM_SLOTS / LLM_CTX above apply to compose too):
#CHAT_MODEL_FILE=Qwen3-14B-Instruct-Q4_K_M.gguf
#EMBED_MODEL_FILE=bge-m3-Q8_0.gguf
#MODELS_DIR=./models
#APP_PORT=8000

# --- CORS ---
# Comma-separated origins allowed to call /chat from a browser, e.g.
# https://clientsite.com,https://www.clientsite.com. Empty = allow any
# origin — fine for local testing, lock this down before going live.
ALLOWED_ORIGINS=

# --- QA conversation review ---
# Every chat turn is logged (with latency + conversation duration) to
# data/conversations.db. Set a secret token to enable the private review
# site at /qa?token=<QA_TOKEN>; leave empty to keep /qa disabled.
QA_TOKEN=

# --- Answer quality (see README "Answer-quality strategy") ---
# Rewrite follow-up messages into standalone search queries before retrieval
# (one extra small LLM call per follow-up turn; first messages never pay it).
QUERY_REWRITE=1
# Strip lines repeated across many crawled pages (cookie banners, menus,
# footers) before chunking/embedding. A line is boilerplate when it appears
# on >= BOILERPLATE_MIN_PAGES pages AND >= BOILERPLATE_PAGE_FRACTION of all.
BOILERPLATE_STRIP=1
BOILERPLATE_MIN_PAGES=4
BOILERPLATE_PAGE_FRACTION=0.3

# --- Crawler ---
CRAWL_MAX_PAGES=50
CRAWL_SAME_DOMAIN=1
# Linked PDF files (detected by .pdf extension) are downloaded and their text
# ingested too. Scanned/image-only PDFs are skipped (no OCR). Set to 0 to
# disable; CRAWL_PDF_MAX_MB skips files larger than this.
CRAWL_PDFS=1
CRAWL_PDF_MAX_MB=20

# --- Where this install writes data (vector store, demo DB) ---
DATA_DIR=data
